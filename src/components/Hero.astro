---
const socialLinks = [
  {
    href: 'https://www.linkedin.com/in/oleksii-levchenko-512781212/',
    label: 'LinkedIn profile',
    src: '/assets/linkedin.png',
    alt: 'LinkedIn',
  },
  {
    href: 'https://github.com/xlevchenko',
    label: 'GitHub profile',
    src: '/assets/github.png',
    alt: 'GitHub',
  },
  {
    href: 'https://t.me/ilevchenko',
    label: 'Telegram profile',
    src: '/assets/telegram.png',
    alt: 'Telegram',
  },
];
---

<section id="profile" aria-label="Hero">
  <div class="hero-inner">
    <div class="hero-photo reveal reveal--left">
      <img
        src="/assets/profile-pic.png"
        alt="Oleksii Levchenko – iOS Developer"
        width="300"
        height="300"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <div class="hero-content reveal reveal--right">
      <p class="hero-greeting">
        Hi there <span class="wave" aria-hidden="true">👋</span>
      </p>

      <h1 class="hero-headline">
        <span class="hero-role">iOS Developer</span>
      </h1>

      <p class="hero-description">
        Bringing modern mobile solutions to life using Swift and SwiftUI, delivering elegant,
        scalable apps that solve real-world problems and delight users.
      </p>

      <div class="hero-actions">
        <a
          href="/assets/CV-Levchenko.pdf"
          download
          class="btn btn-outline"
        >
          Download CV
        </a>
        <a href="#contact" class="btn btn-solid">Contact Info</a>
      </div>

      <ul class="social-links" role="list" aria-label="Social media profiles">
        {
          socialLinks.map(({ href, label, src, alt }) => (
            <li>
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
                class="social-link"
              >
                <img src={src} alt={alt} width="48" height="48" loading="lazy" />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  #profile {
    padding-block: var(--space-3xl) var(--space-2xl);
  }

  .hero-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
    display: flex;
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
    min-height: calc(100svh - var(--nav-height));
  }

  /* ── Profile photo ── */
  .hero-photo {
    flex-shrink: 0;
    width: clamp(160px, 22vw, 300px);
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    overflow: hidden;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* ── Text content ── */
  .hero-content {
    flex: 1;
    min-width: 0;
    max-width: 600px;
  }

  .hero-greeting {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.6rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .wave {
    display: inline-block;
    animation: wave 2.5s ease-in-out infinite;
    transform-origin: 70% 70%;
    margin-left: 0.2rem;
  }

  @keyframes wave {
    0%, 60%, 100% { transform: rotate(0deg); }
    10% { transform: rotate(14deg); }
    20% { transform: rotate(-8deg); }
    30% { transform: rotate(14deg); }
    40% { transform: rotate(-4deg); }
    50% { transform: rotate(10deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .wave {
      animation: none;
    }
  }

  .hero-headline {
    font-weight: 900;
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .hero-role {
    font-family: 'Gilroy Bold', 'Poppins', system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 3.25rem);
    color: var(--color-accent);
    letter-spacing: -0.03em;
    display: inline-block;
    line-height: 1.05;
  }

  .hero-description {
    font-family: var(--font-display-regular);
    font-size: clamp(0.95rem, 1.5vw, 1.2rem);
    color: var(--color-text-muted);
    line-height: 1.5;
    letter-spacing: -0.01em;
    margin-bottom: 1.75rem;
    max-width: 520px;
  }

  /* ── Buttons ── */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.625rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-display-semibold);
    font-size: 0.95rem;
    font-weight: 600;
    transition: background-color var(--transition-base), color var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
    white-space: nowrap;
  }

  .btn-outline {
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
    background: transparent;
  }

  .btn-outline:hover,
  .btn-outline:focus-visible {
    background-color: var(--color-accent);
    color: #fff;
    box-shadow: 0 4px 12px rgba(213, 69, 27, 0.25);
  }

  .btn-solid {
    color: #fff;
    background-color: var(--color-accent);
    border: 2px solid var(--color-accent);
  }

  .btn-solid:hover,
  .btn-solid:focus-visible {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    box-shadow: 0 4px 12px rgba(213, 69, 27, 0.3);
  }

  /* ── Social links ── */
  .social-links {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    opacity: 0.85;
    transition: opacity var(--transition-base), transform var(--transition-base);
  }

  .social-link img {
    width: clamp(2.25rem, 5vw, 3rem);
    height: clamp(2.25rem, 5vw, 3rem);
    object-fit: contain;
  }

  .social-link:hover,
  .social-link:focus-visible {
    opacity: 1;
    transform: scale(1.15) translateY(-2px);
  }

  /* ── Mobile layout ── */
  @media (max-width: 768px) {
    #profile {
      padding-block: var(--space-lg) var(--space-xl);
    }

    .hero-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      min-height: auto;
      gap: 1.5rem;
    }

    .hero-photo {
      width: clamp(140px, 40vw, 200px);
    }

    .hero-content {
      align-items: center;
      display: flex;
      flex-direction: column;
    }

    .hero-greeting {
      text-align: center;
    }

    .hero-description {
      text-align: center;
      margin-inline: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .social-links {
      justify-content: center;
      gap: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .hero-role {
      font-size: clamp(1.6rem, 10vw, 2.4rem);
    }
  }
</style>
