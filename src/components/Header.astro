---
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#projects', label: 'Projects' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="site-header" role="banner">
  <div class="header-inner">
    <span class="logo" aria-label="Oleksii Levchenko">Oleksii Levchenko</span>

    <!-- Desktop navigation -->
    <nav class="nav-desktop" aria-label="Primary navigation">
      <ul class="nav-list" role="list">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="nav-link">
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Mobile hamburger button -->
    <button
      class="hamburger"
      type="button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>
  </div>

  <!-- Mobile navigation overlay -->
  <nav
    id="mobile-menu"
    class="nav-mobile"
    aria-label="Mobile navigation"
    aria-hidden="true"
  >
    <ul class="nav-mobile-list" role="list">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a href={href} class="nav-mobile-link">
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  /* ── Header shell ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    width: 100%;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    padding-inline: var(--container-padding);
    max-width: calc(var(--container-max) + var(--container-padding) * 2);
    margin-inline: auto;
  }

  /* ── Logo ── */
  .logo {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    color: var(--color-text-primary);
    position: relative;
    user-select: none;
    transition: color var(--transition-base);
  }

  .logo::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 3px;
    background-color: var(--color-accent);
    transition: width var(--transition-base);
    border-radius: 2px;
  }

  .logo:hover {
    color: var(--color-accent);
  }

  .logo:hover::after {
    width: 100%;
  }

  /* ── Desktop nav ── */
  .nav-desktop {
    display: flex;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-primary);
    padding: 0.5rem 0.875rem;
    border-radius: var(--radius-sm);
    position: relative;
    transition: color var(--transition-base), background-color var(--transition-base);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    width: 0;
    height: 2px;
    background-color: var(--color-accent);
    transition: width var(--transition-base);
    transform: translateX(-50%);
    border-radius: 2px;
  }

  .nav-link:hover {
    color: var(--color-accent);
    background-color: var(--color-accent-subtle);
  }

  .nav-link:hover::after {
    width: 60%;
  }

  /* ── Hamburger button ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 20px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    position: relative;
    z-index: 200;
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text-primary);
    border-radius: 2px;
    transition: transform var(--transition-base), opacity var(--transition-base), background-color var(--transition-base);
    transform-origin: center;
  }

  /* Open state */
  .hamburger[aria-expanded='true'] .hamburger-bar:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
    background-color: var(--color-accent);
  }

  .hamburger[aria-expanded='true'] .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger[aria-expanded='true'] .hamburger-bar:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
    background-color: var(--color-accent);
  }

  /* ── Mobile overlay nav ── */
  .nav-mobile {
    position: fixed;
    inset: 0;
    background-color: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-slow), visibility var(--transition-slow);
    z-index: 150;
  }

  .nav-mobile[aria-hidden='false'] {
    opacity: 1;
    visibility: visible;
  }

  .nav-mobile-list {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .nav-mobile-list li {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    transition-delay: 0s;
  }

  .nav-mobile[aria-hidden='false'] .nav-mobile-list li {
    opacity: 1;
    transform: none;
    transition-delay: 0.25s;
  }

  .nav-mobile[aria-hidden='false'] .nav-mobile-list li:nth-child(2) {
    transition-delay: 0.32s;
  }

  .nav-mobile[aria-hidden='false'] .nav-mobile-list li:nth-child(3) {
    transition-delay: 0.39s;
  }

  .nav-mobile-link {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 8vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text-primary);
    position: relative;
    padding: 0.25rem 0.5rem;
    transition: color var(--transition-base);
  }

  .nav-mobile-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background-color: var(--color-accent);
    transition: width var(--transition-base);
    transform: translateX(-50%);
    border-radius: 2px;
  }

  .nav-mobile-link:hover {
    color: var(--color-accent);
  }

  .nav-mobile-link:hover::after {
    width: 80%;
  }

  /* ── Responsive: show hamburger, hide desktop nav ── */
  @media (max-width: 768px) {
    .nav-desktop {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  const hamburger = document.querySelector<HTMLButtonElement>('.hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = mobileMenu?.querySelectorAll<HTMLAnchorElement>('.nav-mobile-link');

  function openMenu() {
    hamburger?.setAttribute('aria-expanded', 'true');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    hamburger?.setAttribute('aria-expanded', 'false');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function toggleMenu() {
    const isOpen = hamburger?.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  }

  hamburger?.addEventListener('click', toggleMenu);

  // Close on link click
  mobileLinks?.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && hamburger?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
      hamburger.focus();
    }
  });

  // Close on scroll
  let lastScroll = window.scrollY;
  window.addEventListener(
    'scroll',
    () => {
      if (Math.abs(window.scrollY - lastScroll) > 40) {
        if (hamburger?.getAttribute('aria-expanded') === 'true') closeMenu();
        lastScroll = window.scrollY;
      }
    },
    { passive: true }
  );
</script>
